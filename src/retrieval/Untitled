import os
import logging
from dotenv import load_dotenv
from openai import OpenAI
from pinecone import Pinecone

load_dotenv()
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

EMBEDDING_MODEL = "text-embedding-3-large"


def get_clients():
    client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
    pc = Pinecone(api_key=os.getenv("PINECONE_API_KEY"))
    index = pc.Index(os.getenv("PINECONE_INDEX_NAME"))
    return client, index


def embed_query(query: str, client: OpenAI) -> list[float]:
    """
    Convert user query into a vector using the same
    embedding model used during ingestion.
    Critical: must use identical model — mismatched models
    produce incompatible vector spaces.
    """
    response = client.embeddings.create(
        input=query,
        model=EMBEDDING_MODEL
    )
    return response.data[0].embedding


def search_pinecone(
    query_vector: list[float],
    index,
    top_k: int = 20,
    ticker_filter: str = None
) -> list[dict]:
    """
    Search Pinecone for most similar chunks to the query vector.
    Returns top_k results with metadata.

    top_k=20 because we fetch more than needed —
    the reranker will trim this down to the best 5-10.

    ticker_filter: optionally restrict search to one company
    e.g. ticker_filter="AAPL" for Apple-only queries
    """
    filter_dict = None
    if ticker_filter:
        filter_dict = {"ticker": {"$eq": ticker_filter}}

    results = index.query(
        vector=query_vector,
        top_k=top_k,
        include_metadata=True,
        filter=filter_dict
    )

    matches = []
    for match in results.matches:
        matches.append({
            "id": match.id,
            "score": match.score,
            "ticker": match.metadata.get("ticker"),
            "filing_type": match.metadata.get("filing_type"),
            "content": match.metadata.get("content"),
            "chunk_index": match.metadata.get("chunk_index")
        })

    return matches


def mmr_rerank(
    query_vector: list[float],
    matches: list[dict],
    top_k: int = 8,
    diversity_weight: float = 0.3
) -> list[dict]:
    """
    Maximal Marginal Relevance reranking.

    Problem with naive top-k: if 5 chunks from the same
    section of a filing are all similar to the query,
    you get 5 nearly identical chunks — redundant context.

    MMR solves this by balancing:
    - Relevance: how similar is this chunk to the query?
    - Diversity: how different is this chunk from already selected chunks?

    diversity_weight=0.3 means 70% relevance, 30% diversity.
    Higher diversity_weight = more varied results, potentially less relevant.
    """
    import numpy as np

    if not matches:
        return []

    # Convert query vector to numpy
    query_vec = np.array(query_vector)

    # Extract content vectors — we use the scores as proxy for similarity
    # since we don't have the raw vectors back from Pinecone
    selected = []
    remaining = matches.copy()

    while len(selected) < top_k and remaining:
        if not selected:
            # First pick — just take highest relevance score
            best = max(remaining, key=lambda x: x["score"])
        else:
            # MMR score = relevance - diversity_weight * max_similarity_to_selected
            # We approximate similarity between chunks using string overlap
            best_score = float("-inf")
            best = None

            for candidate in remaining:
                relevance = candidate["score"]

                # Approximate diversity: penalize if content overlaps with selected
                max_overlap = 0
                for sel in selected:
                    # Simple word overlap as diversity proxy
                    cand_words = set(candidate["content"].lower().split())
                    sel_words = set(sel["content"].lower().split())
                    if cand_words and sel_words:
                        overlap = len(cand_words & sel_words) / len(cand_words | sel_words)
                        max_overlap = max(max_overlap, overlap)

                mmr_score = relevance - diversity_weight * max_overlap

                if mmr_score > best_score:
                    best_score = mmr_score
                    best = candidate

        selected.append(best)
        remaining.remove(best)

    return selected


def retrieve(
    query: str,
    top_k: int = 8,
    ticker_filter: str = None,
    use_mmr: bool = True
) -> list[dict]:
    """
    Main retrieval function — call this from the generator.

    Flow:
    1. Embed the query
    2. Search Pinecone for top 20 similar chunks
    3. MMR rerank to top 8 diverse, relevant chunks
    4. Return chunks ready for the generator
    """
    client, index = get_clients()

    # Step 1 — embed query
    logger.info(f"Retrieving for query: '{query[:80]}...'")
    query_vector = embed_query(query, client)

    # Step 2 — search Pinecone
    matches = search_pinecone(query_vector, index, top_k=20, ticker_filter=ticker_filter)
    logger.info(f"Pinecone returned {len(matches)} matches")

    # Step 3 — MMR rerank
    if use_mmr and len(matches) > top_k:
        matches = mmr_rerank(query_vector, matches, top_k=top_k)
        logger.info(f"After MMR reranking: {len(matches)} chunks")

    return matches